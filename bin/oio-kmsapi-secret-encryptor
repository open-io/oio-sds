import argparse
import json
import sys

from oio.account.kms_encryptor import KmsEncryptor
from oio.cli import get_logger_from_args, make_logger_args_parser
from oio.common.configuration import read_conf
from oio.common.utils import request_id

SEPARATOR = "/"


def make_arg_parser():
    log_parser = make_logger_args_parser()
    descr = KmsEncryptor.__doc__
    parser = argparse.ArgumentParser(description=descr, parents=[log_parser])
    parser.formatter_class = argparse.RawDescriptionHelpFormatter
    parser.add_argument(
        "--conf",
        dest="config",
        required=True,
        help="Account service configuration file",
    )
    parser.add_argument(
        "--accounts",
        dest="accounts",
        nargs="+",
        metavar="<account_name>",
        default=None,
        help="Only list buckets from listed accounts",
    )
    parser.add_argument(
        "--buckets",
        nargs="+",
        metavar="<bucket_name>",
        help="Bucket name(s)",
    )
    parser.add_argument(
        "--marker",
        dest="marker",
        default=None,
        help=f"Marker for paging. Format=account{SEPARATOR}container ",
    )
    parser.add_argument(
        "--dry-run",
        dest="dry_run",
        default=False,
        action="store_true",
        help="Enable dry-run mode, only print kms api secret encryption"
        " that would be made",
    )
    return parser


def main():
    args = make_arg_parser().parse_args()
    logger = get_logger_from_args(args)
    conf_file = args.config
    conf = read_conf(conf_file, "account-server")
    account_marker, bucket_marker = (None, None)
    if args.marker:
        parts = args.marker.split(SEPARATOR, 1)
        if len(parts) != 2:
            logger.error(
                f"Marker wrong format, expected format: account{SEPARATOR}container"
            )
            sys.exit(1)
        account_marker = parts[0] if parts[0] else None
        bucket_marker = parts[1] if parts[1] else None
    accounts = args.accounts
    buckets = args.buckets
    if buckets:
        buckets = [{"name": bucket} for bucket in buckets]
        if not accounts or (accounts and len(accounts) != 1):
            logger.error("Buckets requires one account name.")
            sys.exit(1)
    reqid = request_id("oio-kmsapi-secret-encryptor-")
    kms_encryptor = KmsEncryptor(
        conf,
        reqid=reqid,
        logger=logger,
        accounts=accounts,
        buckets=buckets,
        acc_marker=account_marker,
        bkt_marker=bucket_marker,
        dry_run=args.dry_run,
        separator=SEPARATOR,
    )
    try:
        result, _ = kms_encryptor.run()
        print(json.dumps(result, indent=4, ensure_ascii=False))
    except KeyboardInterrupt:
        logger.info("Exiting...")
        print(f"Next marker: {kms_encryptor.progress}")
    except Exception as exc:
        logger.critical("Failure during process %s", exc)
        print(f"Next marker: {kms_encryptor.progress}")
        sys.exit(1)
    sys.exit(0)


if __name__ == "__main__":
    main()
